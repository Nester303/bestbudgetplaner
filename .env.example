# ============================================================
#  .env — skopiuj do .env i uzupełnij wartości
#  NIGDY nie commituj .env do repozytorium!
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=budzetapp_db
POSTGRES_USER=budzetapp_user
POSTGRES_PASSWORD=ZMIEN_NA_SILNE_HASLO_MIN_32_ZNAKI

# --- Redis ---
REDIS_PASSWORD=ZMIEN_NA_SILNE_HASLO_REDIS

# --- Flask ---
# Generuj: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ZMIEN_NA_LOSOWY_KLUCZ_64_ZNAKI
JWT_SECRET_KEY=ZMIEN_NA_INNY_LOSOWY_KLUCZ_64_ZNAKI

# --- Mail (np. Gmail App Password) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=twoj@gmail.com
MAIL_PASSWORD=haslo_aplikacji_gmail
MAIL_DEFAULT_SENDER=BudzetApp <noreply@twojastrona.pl>

# --- Gunicorn (produkcja) ---
GUNICORN_WORKERS=4
GUNICORN_THREADS=2

# --- Cloudflare ---
# Pobierz token: cloudflared tunnel token <nazwa-tunelu>
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiTVkuVE9LRU4uSEVSRSJ9...

# --- Domena ---
DOMAIN=twojastrona.pl
